# Keep the build context small and avoid leaking secrets into image layers.
.git
.gitignore
.gitattributes

# Build artefacts
build/
out/
.gradle/

# IDE
.idea/
.vscode/
*.iml

# Local secrets / env files
.env
.env.*
!.env.example
!.env.prod.example

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Docker meta (avoid recursive copies)
Dockerfile
docker-compose*.yml
.dockerignore

# Cursor / project meta
.cursorrules
README.md
